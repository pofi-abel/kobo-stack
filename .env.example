PORT=4000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/kobo-bank?retryWrites=true&w=majority

# JWT for customers
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=24h

# NibssByPhoenix credentials (from onboarding response)
NIBSS_BASE_URL=your_nibss_base_url
NIBSS_API_KEY=your_nibss_api_key
NIBSS_API_SECRET=your_nibss_api_secret

# Admin key to protect BVN/NIN seeding endpoints
ADMIN_KEY=change_this_to_a_long_random_admin_key
